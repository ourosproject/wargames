# Copy to .env and fill in. .env is gitignored — secrets never enter the repo.
# These names are referenced (by name) from range.config.json.

# Attacker box SSH password (if it uses password auth)
RANGE_ATTACKER_PW=

# Windows / password-auth target
RANGE_WIN_PW=

# Sudo password on the SIEM host (used only to read the alerts log for the live feed)
RANGE_SIEM_SUDO_PW=
